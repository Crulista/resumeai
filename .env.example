# ================================================
# ResumeAI — Environment Variables
# ================================================
# STEP 1: Copy this file to .env in this same folder:
#         cp .env.example .env
#
# STEP 2: Replace every value below with your actual credentials
#
# STEP 3: Verify everything works:
#         cd server && node checkSetup.js
# ================================================

# Server (these defaults work fine for local dev)
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ---- DATABASE ----
# Get from: supabase.com → Your Project → Settings → Database → Connection string → URI
# IMPORTANT: Replace [YOUR-PASSWORD] with your actual DB password
# If "ENOTFOUND" error: use the "Session Mode" or "Transaction Mode" pooler URL instead
DATABASE_URL=postgresql://postgres:REPLACE_WITH_YOUR_PASSWORD@db.REPLACE_WITH_PROJECT_ID.supabase.co:5432/postgres

# ---- GOOGLE OAUTH ----
# Get from: console.cloud.google.com → APIs & Services → Credentials → Create OAuth 2.0 Client
# Add http://localhost:5173 to Authorized JavaScript Origins AND Redirect URIs
GOOGLE_CLIENT_ID=REPLACE_ME
GOOGLE_CLIENT_SECRET=REPLACE_ME

# ---- JWT SECRET ----
# Generate by running this in your terminal:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Paste the output here:
JWT_SECRET=REPLACE_WITH_GENERATED_SECRET

# ---- ANTHROPIC AI ----
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=REPLACE_ME

# ---- RAZORPAY ----
# Get from: razorpay.com → Settings → API Keys → Generate Key
# For Plan ID: Dashboard → Subscriptions → Plans → Create Plan (₹99/week, amount in paise = 9900)
RAZORPAY_KEY_ID=REPLACE_ME
RAZORPAY_KEY_SECRET=REPLACE_ME
RAZORPAY_PLAN_ID=REPLACE_ME
RAZORPAY_WEBHOOK_SECRET=REPLACE_ME
